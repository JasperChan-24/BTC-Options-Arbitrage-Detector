# ── OKX API Credentials (optional, can also set via frontend) ──
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_SIMULATED=true

# ── Deribit API Credentials (optional, can also set via frontend) ──
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# ── Server Config ──
SERVER_PORT=3001

# ── Engine Defaults (optional) ──
# MIN_VOLUME=10
# MAX_SPREAD_PCT=20
# AUTO_EXECUTE=true
# INCLUDE_FEE=true
# RISK_PCT=25

# ── Email Notifications (optional) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# NOTIFY_EMAIL=recipient@example.com
